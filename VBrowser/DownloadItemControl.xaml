<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VBrowser.DownloadItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Padding="16"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        CornerRadius="12">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        x:Name="FileNameText"
                        FontSize="16"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis"/>
                    <TextBlock
                        x:Name="SourceUrlText"
                        FontSize="12"
                        Opacity="0.7"
                        TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <TextBlock
                    x:Name="StatusText"
                    Grid.Column="1"
                    FontSize="12"
                    FontWeight="SemiBold"
                    VerticalAlignment="Top"
                    Margin="12,2,0,0"/>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ProgressBar
                    x:Name="ProgressBar"
                    Minimum="0"
                    Maximum="100"
                    Height="8"/>

                <TextBlock
                    x:Name="ProgressText"
                    Grid.Column="1"
                    FontSize="12"
                    Opacity="0.7"
                    VerticalAlignment="Center"/>
            </Grid>

            <StackPanel Grid.Row="2" Spacing="2">
                <TextBlock
                    x:Name="SpeedText"
                    FontSize="12"
                    Opacity="0.75"/>
                <TextBlock
                    x:Name="EtaText"
                    FontSize="12"
                    Opacity="0.75"/>
                <TextBlock
                    x:Name="ResultFilePathText"
                    FontSize="12"
                    Opacity="0.58"
                    TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="PauseButton" Content="Pause" Click="Pause_Click"/>
                    <Button x:Name="ResumeButton" Content="Resume" Click="Resume_Click"/>
                    <Button x:Name="RetryButton" Content="Retry" Click="Retry_Click"/>
                    <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="OpenFileButton" Content="Open File" Click="OpenFile_Click"/>
                    <Button x:Name="OpenFolderButton" Content="Open Folder" Click="OpenFolder_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
