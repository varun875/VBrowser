<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VBrowser.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Background>
        <SolidColorBrush Color="{ThemeResource SystemAltHighColor}"/>
    </Page.Background>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:ConnectionId='6' Width="40" Height="40" CornerRadius="20"                         >
                    <SymbolIcon Symbol="Back"/>
                </Button>

                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Downloads" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock x:ConnectionId='7'
                        x:Name="SummaryText"
                        Text="Start a file download to see live progress and quick actions here."
                        FontSize="13"
                        Opacity="0.72"/>
                </StackPanel>
            </StackPanel>

            <Button x:ConnectionId='5'
                x:Name="ClearFinishedButton"
                Grid.Column="1"
                Content="Clear Finished"
                                           
                VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Border x:ConnectionId='2'
                x:Name="EmptyStatePanel"
                Padding="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="520">
                <StackPanel Spacing="10">
                    <TextBlock
                        Text="No downloads yet"
                        FontSize="22"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="Downloads will show up here with live progress, speed, and quick actions once you start grabbing files."
                        FontSize="14"
                        Opacity="0.72"
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <ScrollViewer x:ConnectionId='3'
                x:Name="DownloadsScrollViewer"
                Visibility="Collapsed">
                <StackPanel x:ConnectionId='4' x:Name="DownloadsStackPanel" Spacing="12"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>

