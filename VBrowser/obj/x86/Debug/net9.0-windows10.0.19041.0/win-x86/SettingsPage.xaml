<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VBrowser.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VBrowser"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Background>
        <SolidColorBrush Color="{ThemeResource SystemAltHighColor}"/>
    </Page.Background>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,24">
            <Button x:ConnectionId='16' x:Name="BackButton"                          Width="40" Height="40" CornerRadius="20">
                <SymbolIcon Symbol="Back"/>
            </Button>
            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16" MaxWidth="600">
                <!-- General Section -->
                <TextBlock Text="General" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,8"/>
                
                <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <ToggleSwitch x:ConnectionId='15' x:Name="DarkModeToggle" Header="Dark Mode" OnContent="On" OffContent="Off"                                 />
                </StackPanel>

                <!-- Tabs Section -->
                <TextBlock Text="Tabs" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8"/>
                
                <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Spacing="8">
                    <ToggleSwitch x:ConnectionId='14' x:Name="VerticalTabsToggle" Header="Vertical Tabs" OnContent="On" OffContent="Off"                                     >
                        <ToolTipService.ToolTip>
                            <ToolTip Content="Show tabs in a vertical sidebar on the left, similar to Microsoft Edge"/>
                        </ToolTipService.ToolTip>
                    </ToggleSwitch>
                    <TextBlock Text="Displays tabs in a collapsible sidebar on the left side of the window" FontSize="12" Opacity="0.6" Margin="0,-4,0,0"/>
                </StackPanel>

                <!-- Privacy Section -->
                <TextBlock Text="Privacy" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8"/>
                
                <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Spacing="12">
                    <ToggleSwitch x:ConnectionId='12' x:Name="ClearDataToggle" Header="Clear browsing data on exit" OnContent="On" OffContent="Off"/>
                    <Button x:ConnectionId='13' x:Name="ClearDataButton" Content="Clear data now"                               HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Search Section -->
                <TextBlock Text="Search" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8"/>
                
                <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Spacing="12">
                    <ComboBox x:ConnectionId='11' x:Name="SearchEngineCombo" Header="Default search engine" Width="300"                                                      >
                        <ComboBoxItem Content="Google" IsSelected="True"/>
                        <ComboBoxItem Content="Bing"/>
                        <ComboBoxItem Content="DuckDuckGo"/>
                        <ComboBoxItem Content="Yahoo"/>
                        <ComboBoxItem Content="Yandex"/>
                    </ComboBox>
                </StackPanel>

                <!-- Default Browser Section -->
                <TextBlock Text="Default Browser" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8"/>

                <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Spacing="10">
                    <TextBlock Text="Status" FontSize="12" Opacity="0.7"/>
                    <TextBlock x:ConnectionId='7' x:Name="DefaultBrowserStatusText" Text="Checking..." FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock x:ConnectionId='8' x:Name="DefaultBrowserDetailsText" Text="Checking Windows default browser associations for HTTP/HTTPS." FontSize="12" Opacity="0.75" TextWrapping="WrapWholeWords"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:ConnectionId='9' x:Name="RefreshDefaultBrowserButton" Content="Check now"                                          />
                        <Button x:ConnectionId='10' x:Name="OpenDefaultAppsButton" Content="Open Windows default apps"                                     Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Windows requires changing default browser in system Settings. VBrowser can detect status and open the right Settings page." FontSize="11" Opacity="0.65" TextWrapping="WrapWholeWords"/>
                </StackPanel>

                <!-- Performance Section -->
                <TextBlock Text="Performance" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8"/>
                
                <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Spacing="12">
                    <ToggleSwitch x:ConnectionId='4' x:Name="MemorySaverToggle" Header="Memory Saver Mode" OnContent="On" OffContent="Off"                                    >
                        <ToolTipService.ToolTip>
                            <ToolTip Content="Reduces memory usage by putting inactive tabs to sleep"/>
                        </ToolTipService.ToolTip>
                    </ToggleSwitch>
                    <TextBlock Text="Frees up memory from inactive tabs" FontSize="12" Opacity="0.6" Margin="0,-8,0,0"/>
                    
                    <ToggleSwitch x:ConnectionId='5' x:Name="HighEfficiencyToggle" Header="High Efficiency Mode" OnContent="On" OffContent="Off"                                       >
                        <ToolTipService.ToolTip>
                            <ToolTip Content="Extends battery life by limiting background activity"/>
                        </ToolTipService.ToolTip>
                    </ToggleSwitch>
                    <TextBlock Text="Saves battery by reducing background activity" FontSize="12" Opacity="0.6" Margin="0,-8,0,0"/>

                    <ToggleSwitch x:ConnectionId='6' x:Name="HardwareAccelerationToggle" Header="Hardware Acceleration" OnContent="On" OffContent="Off" IsOn="True"                                             >
                        <ToolTipService.ToolTip>
                            <ToolTip Content="Uses GPU acceleration for smoother rendering and video playback"/>
                        </ToolTipService.ToolTip>
                    </ToggleSwitch>
                    <TextBlock Text="Restart required. Turn off to troubleshoot high WebView2 GPU process usage." FontSize="12" Opacity="0.6" Margin="0,-8,0,0"/>
                </StackPanel>

                <!-- Homepage Section -->
                <TextBlock Text="Homepage" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8"/>
                
                <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Homepage URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                    <TextBox x:ConnectionId='2' x:Name="HomepageTextBox" Grid.Row="1" Grid.Column="0" PlaceholderText="https://www.google.com" Margin="0,0,12,0" VerticalAlignment="Bottom"/>
                    <Button x:ConnectionId='3' x:Name="SaveHomepageButton" Grid.Row="1" Grid.Column="1" Content="Save"                                  Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

