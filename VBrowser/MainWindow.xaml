<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VBrowser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VBrowser"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VBrowser">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <!-- Vertical tab sidebar (collapsed by default) -->
            <ColumnDefinition x:Name="VerticalTabColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Vertical Tab Sidebar -->
        <Grid x:Name="VerticalTabSidebar" Grid.Column="0" Visibility="Collapsed"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sidebar Header -->
            <StackPanel Grid.Row="0" Padding="12,10" Spacing="8">
                <Grid>
                    <TextBlock Text="Tabs" FontSize="13" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Opacity="0.8"/>
                    <Button x:Name="CollapseSidebarButton" Click="CollapseSidebar_Click"
                            HorizontalAlignment="Right"
                            Width="28" Height="28" CornerRadius="6"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            ToolTipService.ToolTip="Collapse sidebar">
                        <FontIcon Glyph="&#xE89F;" FontSize="12"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Vertical Tab List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6,0">
                <StackPanel x:Name="VerticalTabContainer" Spacing="2">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition/>
                            <RepositionThemeTransition IsStaggeringEnabled="True"/>
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                </StackPanel>
            </ScrollViewer>

            <!-- New Tab Button at Bottom of Sidebar -->
            <StackPanel Grid.Row="2" Padding="6,6" Spacing="4">
                <Border x:Name="VerticalNewTabButton" Tapped="NewTab_Tapped"
                        Height="36" CornerRadius="8" Padding="10,0"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderThickness="0"
                        ToolTipService.ToolTip="New Tab">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <SymbolIcon Symbol="Add" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="New tab" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border x:Name="VerticalNewPrivateTabButton" Tapped="NewPrivateTab_Tapped"
                        Height="36" CornerRadius="8" Padding="10,0"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="New Private Tab">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE72E;" FontSize="14"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="New private tab" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

                                    <!-- Toolbar -->
            <Grid x:Name="ToolbarGrid" Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Tabs Row -->
                <Grid Grid.Row="0" Padding="8,4,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Vertical Tabs Toggle -->
                    <Button x:Name="ExpandSidebarButton" Grid.Column="0"
                            Click="ExpandSidebar_Click"
                            Visibility="Collapsed"
                            Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            ToolTipService.ToolTip="Show vertical tabs"
                            Margin="4,0,8,0" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE89F;" FontSize="15" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </Button>

                    <!-- Horizontal Tab Strip -->
                    <TabView x:Name="BrowserTabView" Grid.Column="1"
                             Margin="4,0" VerticalAlignment="Bottom" Height="36"
                             Background="Transparent" BorderThickness="0"
                             IsAddTabButtonVisible="True"
                             AddTabButtonClick="BrowserTabView_AddTabButtonClick"
                             SelectionChanged="BrowserTabView_SelectionChanged"
                             TabCloseRequested="BrowserTabView_TabCloseRequested">
                        <TabViewItem x:Name="Tab1" IsClosable="True" Header="New Tab">
                            <TabViewItem.IconSource>
                                <SymbolIconSource Symbol="World"/>
                            </TabViewItem.IconSource>
                        </TabViewItem>
                    </TabView>
                </Grid>

                <!-- Row 1: Navigation + Address Bar + Menu -->
                <Grid Grid.Row="1" Padding="12,6,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Navigation Buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="BackButton" Click="BackButton_Click"
                                Width="34" Height="34" CornerRadius="17"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Button>
                        <Button x:Name="ForwardButton" Click="ForwardButton_Click"
                                Width="34" Height="34" CornerRadius="17"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <FontIcon Glyph="&#xE72A;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Button>
                        <Button x:Name="RefreshButton" Click="RefreshButton_Click"
                                Width="34" Height="34" CornerRadius="17"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Button>
                    </StackPanel>

                    <!-- Address Bar -->
                    <Border x:Name="AddressBarBorder" Grid.Column="1" HorizontalAlignment="Stretch"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            CornerRadius="18" Height="36"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="SecurityIndicatorButton" Grid.Column="0" Click="SecurityIndicator_Click"
                                    Width="28" Height="28" CornerRadius="14" Background="Transparent" BorderThickness="0" Padding="0" Margin="4,0,0,0">
                                <FontIcon x:Name="SecurityIcon" Glyph="&#xE72E;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Button>

                            <AutoSuggestBox x:Name="AddressBar" Grid.Column="1" Background="Transparent" BorderThickness="0" CornerRadius="0"
                                            FontSize="14" FontWeight="Normal" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="2,0,0,0"
                                            UpdateTextOnSelect="True" TextChanged="AddressBar_TextChanged" SuggestionChosen="AddressBar_SuggestionChosen"
                                            QuerySubmitted="AddressBar_QuerySubmitted" KeyDown="AddressBar_KeyDown" GotFocus="AddressBar_GotFocus"
                                            LostFocus="AddressBar_LostFocus" PointerPressed="AddressBar_PointerPressed"
                                            PlaceholderText="Search the web or type a URL" Text="https://www.google.com/">
                                <AutoSuggestBox.Resources>
                                    <Style TargetType="TextBox">
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="8,0,8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </AutoSuggestBox.Resources>
                            </AutoSuggestBox>

                            <Button x:Name="ClearAddressButton" Grid.Column="2" Click="ClearAddress_Click" Visibility="Collapsed"
                                    Width="26" Height="26" CornerRadius="13" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,4,0">
                                <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Button>

                            <Button x:Name="GoButton" Grid.Column="4" Click="GoButton_Click" Visibility="Collapsed"
                                    Width="26" Height="26" CornerRadius="13" Margin="0,0,4,0"
                                    Background="Transparent" BorderThickness="0">
                                <FontIcon Glyph="&#xE72A;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Extensions and Menu -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0" VerticalAlignment="Center">
                        <!-- Extensions Button -->
                        <Button x:Name="ExtensionsButton" Width="34" Height="34" CornerRadius="17" 
                                Background="Transparent" BorderThickness="0" Padding="0"
                                ToolTipService.ToolTip="Extensions" Click="ExtensionsButton_Click">
                            <FontIcon Glyph="&#xEA86;" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Manage Extensions" Icon="Setting" Click="ManageExtensions_Click"/>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="No extensions installed"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        
                        <!-- Menu -->
                        <Button Width="34" Height="34" CornerRadius="17" Background="Transparent" BorderThickness="0" Padding="0">
                            <FontIcon Glyph="&#xE712;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Button.Flyout>
                                <MenuFlyout>
                                <MenuFlyoutItem Text="New Tab" Click="NewTab_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Add"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="New Private Tab" Click="NewPrivateTab_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE72E;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="History" Click="History_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Clock"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="Downloads" Click="Downloads_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Download"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="Clear browsing data" Click="ClearBrowsingData_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Delete"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="Copy Link" Click="CopyLink_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Copy"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Settings" Click="Settings_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Setting"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="Flags" Click="Flags_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7BA;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="About" Click="About_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Help"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Progress Bar -->
            <ProgressBar x:Name="LoadingProgress" Grid.Row="0" VerticalAlignment="Bottom" IsIndeterminate="True" Visibility="Collapsed" Height="2"/>

            <!-- Certificate Warning Bar -->
            <Border x:Name="CertWarningBar" Grid.Row="1" VerticalAlignment="Top"
                    Visibility="Collapsed"
                    Background="#FFF3CD" Padding="10,8"
                    BorderBrush="#FFECB5" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="16" Foreground="#856404" Margin="0,0,8,0"/>
                    <TextBlock x:Name="CertWarningText" Grid.Column="1"
                               Text="Your connection to this site is not secure"
                               Foreground="#856404" FontSize="13" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button x:Name="CertProceedButton" Grid.Column="2" Content="Proceed anyway"
                            Click="CertProceed_Click"
                            Background="Transparent" Foreground="#856404"
                            BorderThickness="1" BorderBrush="#856404"
                            CornerRadius="4" Padding="10,4" Margin="8,0"
                            FontSize="12"/>
                    <Button x:Name="CertGoBackButton" Grid.Column="3" Content="Go back"
                            Click="CertGoBack_Click"
                            Background="#856404" Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4" Padding="10,4"
                            FontSize="12"/>
                </Grid>
            </Border>

            <!-- Frame for page navigation -->
            <Frame x:Name="MainFrame" Grid.Row="1"/>
        </Grid>
    </Grid>
</Window>


