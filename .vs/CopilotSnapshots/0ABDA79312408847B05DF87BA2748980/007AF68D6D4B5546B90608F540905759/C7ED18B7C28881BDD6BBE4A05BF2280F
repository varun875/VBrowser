        /// <summary>
        /// When true, this tab will not record browsing history and uses
        /// an isolated user-data folder so cookies/cache are discarded on close.
        /// </summary>
        public bool IsPrivate { get; set; }

        public WebView2? WebViewControl => WebView;

        public BrowserPage()
